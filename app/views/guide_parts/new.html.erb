<%= render partial: "guide_parts/common/header", locals: { edition: @edition, reviewer: @reviewer } %>

<div class="govuk-grid-row">
  <div class="govuk-grid-column-full">
    <%= render "govuk_publishing_components/components/heading", {
      text: "Add new chapter",
      heading_level: 2,
      font_size: "l",
      margin_bottom: 5,
      margin_top: 5,
    } %>
  </div>

  <%= form_with url: edition_guide_parts_path(@edition), data: { module: "unsaved-changes-prompt" } do %>

    <%= render partial: "guide_parts/common/form_fields", locals: { edition: @edition, part: @part } %>

  <% end %>
</div>
