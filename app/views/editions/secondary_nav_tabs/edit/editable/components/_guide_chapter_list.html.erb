<%= render "govuk_publishing_components/components/heading", {
  text: "Chapters",
  heading_level: 3,
  font_size: "m",
  margin_bottom: 5,
} %>

<% if edition.parts.presence %>
  <%= render "govuk_publishing_components/components/accordion", {
    disable_ga4: true,
    heading_level: 4,
    items: edition.parts.sort_by(&:order).map do |part|
      { 
        heading: { text: part.title }, 
        content: { html: render(partial: "editions/secondary_nav_tabs/edit/editable/components/part", locals: { edition: @edition, part: }) },
        expanded: part.errors.any?,
      }
    end,
  } %>
<% end %>
