<%= f.hidden_field :artefact_id %>

<%
  if params.dig("downtime", "start_time(4i)")
    hour_start = params.dig("downtime", "start_time(4i)").to_i
  else
    hour_start = 0
  end

  if params.dig("downtime", "start_time(5i)")
    minute_start = params.dig("downtime", "start_time(5i)").to_i
  else
    minute_start = 1
  end

  if params.dig("downtime", "end_time(4i)")
    hour_end = params.dig("downtime", "end_time(4i)").to_i
  else
    hour_end = 0
  end

  if params.dig("downtime", "end_time(5i)")
    minute_end = params.dig("downtime", "end_time(5i)").to_i
  else
    minute_end = 1
  end
%>

<%= render "govuk_publishing_components/components/datetime_fields", {
  prefix: "downtime",
  field_name: "start_time",
  date_heading: "From date",
  time_heading: "From time",
  date_hint: "For example, 01 08 2022",
  time_hint: "For example, 9:30 or 19:30",
  error_items: errors_for(f.object.errors, :start_time),
  year: {
    name: "downtime[start_time(1i)]",
    label: "Year",
    value: params.dig("downtime", "start_time(1i)") || @downtime.start_time&.year,
    width: 4
  },
  month: {
    name: "downtime[start_time(2i)]",
    label: "Month",
    value: params.dig("downtime", "start_time(2i)") || @downtime.start_time&.month,
    width: 2
  },
  day: {
    id: "downtime_start_time",
    name: "downtime[start_time(3i)]",
    label: "Day",
    value: params.dig("downtime", "start_time(3i)") || @downtime.start_time&.day,
    width: 2
  },
  hour: {
    value: hour_start
  },
  minute: {
    value: minute_start
  }
} %>

